{
    "name": "klehm/content-blocks",
    "description": "Modular page builder for Symfony — entities, admin UI, form integration.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": ["symfony", "symfony-bundle", "page-builder", "cms", "content", "blocks", "live-components"],
    "homepage": "https://github.com/klehm/content-blocks-project",
    "support": {
        "issues": "https://github.com/klehm/content-blocks-project/issues",
        "source": "https://github.com/klehm/content-blocks"
    },
    "authors": [
        {
            "name": "Clément Muller",
            "email": "klehm.muller@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "doctrine/orm": "^2.12 || ^3.0",
        "symfony/form": "^6.4 || ^7.0 || ^8.0",
        "symfony/framework-bundle": "^6.4 || ^7.0 || ^8.0",
        "symfony/http-kernel": "^6.4 || ^7.0 || ^8.0",
        "symfony/security-csrf": "^6.4 || ^7.0 || ^8.0",
        "symfony/twig-bundle": "^6.4 || ^7.0 || ^8.0",
        "symfony/ux-live-component": "^2.0",
        "symfony/ux-twig-component": "^2.0",
        "symfony/stimulus-bundle": "^2.0",
        "twig/twig": "^3.10"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "ContentBlocks\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ContentBlocks\\Tests\\": "tests/",
            "ContentBlocks\\Kit\\": "../content-blocks-kit/src/"
        }
    },
    "extra": {
        "symfony": {
            "bundle": "ContentBlocks\\ContentBlocksBundle"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
