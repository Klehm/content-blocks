{% block content_area_widget %}
    {{ form_widget(form) }}
    {% if is_pending %}
        <div class="cb-launcher cb-launcher--pending">
            <p class="cb-launcher__pending-message">
                {{ 'cb.builder.pending'|trans({}, 'content_blocks') }}
            </p>
        </div>
    {% else %}
        {% include '@ContentBlocks/builder/launcher.html.twig' with {
            area: content_area,
            iframeUrl: cb_preview_url(content_area),
            enableReplace: enable_replace ?? true,
            enableImportExport: enable_import_export ?? true,
            topbarActions: topbar_actions|default([]),
        } only %}
    {% endif %}
{% endblock %}
