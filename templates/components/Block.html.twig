<div{{ attributes }}>
    <div class="cb-block__edit-form" data-controller="cb-autosave cb-block-styling-form">
        {# Apply the form theme inside the component so the rendering
           doesn't depend on the host app's global twig.form_themes
           config — the builder must look the same in every environment.

           Important: each `{% form_theme %}` call REPLACES the local theme
           stack on the FormView — it does not append. We pass all themes
           in a single call so they actually stack. Resolution order is
           reverse of the array (last entry checked first):

             1. block-author theme (highest) — overrides block's own fields
             2. styling_widgets              — renders the styling sub-form
             3. cb_form_theme (lowest)       — generic fallback (cb-form-*)

           A block-author theme defining cb_*_widget blocks would override
           the styling widgets too, which is the desired escape hatch. #}
        {% set _themes = [
            '@ContentBlocks/form/cb_form_theme.html.twig',
            '@ContentBlocks/form/styling_widgets.html.twig',
        ] %}
        {% if this.blockType and this.blockType.formTheme %}
            {% set _themes = _themes|merge([this.blockType.formTheme]) %}
        {% endif %}
        {% form_theme form with _themes %}

        {{ form_start(form) }}

            {# Group the block's own fields into tabs by their `data-cb-group`
               attribute (set via the field's `attr` option in buildForm).
               Fields without the attribute fall into the default "General"
               tab; the styling sub-form is always appended as a trailing
               "Style" tab. Group labels are run through the content_blocks
               translation domain, so a block can pass either a literal label
               or a translation key as `data-cb-group`.

               Every field stays rendered — inactive panels are only hidden —
               so autosave still serializes hidden tabs and server-side
               validation is unaffected. The cb-tabs Stimulus controller
               toggles visibility; Live's external-mutation tracker re-applies
               the active tab across morphs. #}
            {% set general_label = 'cb.block.tab.general'|trans({}, 'content_blocks') %}
            {% set style_label = 'cb.block.tab.style'|trans({}, 'content_blocks') %}

            {% set order = [] %}
            {% set buckets = {} %}
            {% for child in form %}
                {% if child.vars.name != 'styling' %}
                    {% set raw = child.vars.attr['data-cb-group']|default('') %}
                    {% set label = raw is empty ? general_label : raw|trans({}, 'content_blocks') %}
                    {% if label not in order %}{% set order = order|merge([label]) %}{% endif %}
                    {% set buckets = buckets|merge({ (label): (buckets[label]|default([]))|merge([child]) }) %}
                {% endif %}
            {% endfor %}

            {# Pin the default "General" tab first, then the rest in
               first-seen order; "Style" is always last. #}
            {% if general_label in order %}
                {% set order = [general_label]|merge(order|filter(l => l != general_label)) %}
            {% endif %}
            {% set order = order|merge([style_label]) %}

            <div class="cb-block__tabs" data-controller="cb-tabs">
                {% if order|length > 1 %}
                    <div class="cb-block__tablist" role="tablist">
                        {% for label in order %}
                            {% set has_error = label == style_label
                                ? not form.styling.vars.valid
                                : buckets[label]|filter(c => not c.vars.valid)|length > 0 %}
                            <button type="button"
                                    class="cb-block__tab{{ has_error ? ' cb-block__tab--has-error' : '' }}"
                                    role="tab"
                                    data-cb-tabs-target="tab"
                                    data-cb-tab="{{ loop.index0 }}"
                                    data-action="cb-tabs#select"
                                    aria-selected="{{ loop.first ? 'true' : 'false' }}"
                                    {% if has_error %}title="{{ 'cb.block.tab.has_errors'|trans({}, 'content_blocks') }}"{% endif %}>
                                {{ label }}
                            </button>
                        {% endfor %}
                    </div>
                {% endif %}

                {% for label in order %}
                    <section class="cb-block__tabpanel"
                             role="tabpanel"
                             data-cb-tabs-target="panel"
                             data-cb-tab="{{ loop.index0 }}"
                             {% if not loop.first %}hidden{% endif %}>
                        {% if label == style_label %}
                            {{ form_row(form.styling) }}
                        {% else %}
                            {% for child in buckets[label] %}
                                {{ form_row(child) }}
                            {% endfor %}
                        {% endif %}
                    </section>
                {% endfor %}
            </div>
        {{ form_end(form) }}

        {# Hidden save trigger clicked by cb-autosave when an input event
           is debounced or a change/focusout fires. Stays a Live Component
           action so the framework still handles `submit + flush`; the
           button is visually hidden because the user-facing Save header
           button is gone (autosave replaces it). #}
        <button type="button"
                data-action="live#action"
                data-live-action-param="save"
                data-cb-sidebar-save
                class="cb-form-sr-only cb-block__edit-action-fallback">
            {{ 'cb.block.save'|trans({}, 'content_blocks') }}
        </button>
    </div>
</div>
