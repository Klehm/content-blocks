<div{{ attributes }}>
    <div class="cb-block__edit-form" data-controller="cb-block-edit-keys">
        {# Builder UI is Bootstrap 5; apply the theme inside the component so it
           doesn't depend on the host app's global twig.form_themes config. #}
        {% form_theme form 'bootstrap_5_layout.html.twig' %}
        {% set formTheme = this.blockType ? this.blockType.formTheme : null %}
        {% if formTheme %}
            {% form_theme form formTheme %}
        {% endif %}

        {{ form_start(form) }}
        {{ form_widget(form) }}
        {{ form_end(form) }}

        {# The Save button is rendered in the sidebar header (cb-builder#saveSidebar
           clicks the [data-cb-sidebar-save] element below). We keep this
           Live Component-bound button in the form so the framework still
           handles `submit + flush` — just visually hidden so it doesn't
           duplicate the header button. The cb-block-edit-keys controller
           still finds it via the saveBtn target. #}
        <button type="button"
                data-action="live#action"
                data-live-action-param="save"
                data-cb-block-edit-keys-target="saveBtn"
                data-cb-sidebar-save
                class="visually-hidden cb-block__edit-action-fallback">
            {{ 'cb.block.save'|trans({}, 'content_blocks') }}
        </button>
    </div>
</div>
