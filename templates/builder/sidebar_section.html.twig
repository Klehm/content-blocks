{# @var form Symfony\Component\Form\FormView #}
{# @var sectionId int #}
<div class="cb-sidebar__section-settings"
     data-controller="cb-section-settings-form cb-autosave"
     data-cb-section-settings-form-section-id-value="{{ sectionId }}">

    {# Single form_theme call so both themes actually stack (each
       form_theme directive replaces the previous local stack, see the
       comment in components/Block.html.twig for the full rationale). #}
    {% form_theme form with [
        '@ContentBlocks/form/cb_form_theme.html.twig',
        '@ContentBlocks/form/styling_widgets.html.twig',
    ] %}
    {{ form_start(form, { 'attr': { 'data-cb-section-settings-form-target': 'form' } }) }}

        {# Two groups stacked vertically — "General" carries everything but
           the styling sub-form, "Styling" carries the styling sub-form. No
           tabs: both groups are always visible and the sidebar content
           scrolls if they exceed the available height. #}
        <section class="cb-sidebar__group">
            <h4 class="cb-sidebar__group-title">
                {{ 'cb.section.settings.tab.general'|trans({}, 'content_blocks') }}
            </h4>
            <div class="cb-sidebar__group-body">
                {% set width_presets = columnCount == 3
                    ? [
                        { label: 'cb.section.settings.column_widths_equal'|trans({}, 'content_blocks'), value: '34,33,33' },
                        { label: '50/25/25', value: '50,25,25' },
                        { label: '25/50/25', value: '25,50,25' },
                        { label: '25/25/50', value: '25,25,50' },
                        { label: '40/30/30', value: '40,30,30' },
                      ]
                    : [
                        { label: '50/50', value: '50,50' },
                        { label: '33/67', value: '33,67' },
                        { label: '40/60', value: '40,60' },
                        { label: '60/40', value: '60,40' },
                        { label: '67/33', value: '67,33' },
                      ] %}
                {% for child in form %}
                    {% if child.vars.name == 'styling' %}
                        {# Rendered in the Styling group below. #}
                    {% elseif child.vars.name == 'columnWidths' %}
                        {# Per-column widths: a hidden CSV field carries the
                           canonical value; the presets + number inputs below
                           are driven by cb-section-settings-form, which keeps
                           the hidden field in sync (and only commits valid
                           sets summing to 100). The number inputs have no
                           `name`, so they never reach the submitted FormData. #}
                        <div class="cb-form-row cb-col-widths">
                            <span class="cb-form-label">
                                {{ 'cb.section.settings.column_widths'|trans({}, 'content_blocks') }}
                            </span>
                            {{ form_widget(child, { attr: { 'data-cb-section-settings-form-target': 'widthsField' } }) }}
                            <div class="cb-col-widths__presets">
                                {% for preset in width_presets %}
                                    <button type="button"
                                            class="cb-col-widths__preset"
                                            data-action="cb-section-settings-form#applyWidthPreset"
                                            data-cb-widths="{{ preset.value }}">{{ preset.label }}</button>
                                {% endfor %}
                                {# Reveals the free inputs below; stays hidden until the
                                   user wants a value the presets don't cover. #}
                                <button type="button"
                                        class="cb-col-widths__preset cb-col-widths__preset--custom"
                                        data-cb-section-settings-form-target="customToggle"
                                        data-action="cb-section-settings-form#showCustomWidths">
                                    {{ 'cb.section.settings.column_widths_custom'|trans({}, 'content_blocks') }}
                                </button>
                            </div>
                            <div class="cb-col-widths__custom" data-cb-section-settings-form-target="customRow" hidden>
                                {% for i in 1..columnCount %}
                                    <span class="cb-col-widths__field">
                                        <input type="number" min="1" max="99" step="1" inputmode="numeric"
                                               class="cb-col-widths__input"
                                               aria-label="{{ 'cb.section.settings.column_width_n'|trans({ '%n%': i }, 'content_blocks') }}"
                                               data-cb-section-settings-form-target="widthInput"
                                               data-action="input->cb-section-settings-form#onWidthInput change->cb-section-settings-form#onWidthCommit">
                                        <span class="cb-col-widths__pct">%</span>
                                    </span>
                                    {%- if not loop.last %}<span class="cb-col-widths__sep">/</span>{% endif -%}
                                {% endfor %}
                                <span class="cb-col-widths__total" data-cb-section-settings-form-target="widthsTotal" aria-live="polite"></span>
                            </div>
                        </div>
                    {% elseif child.vars.name == 'maxWidth' %}
                        {# Only meaningful when widthMode is "centered" —
                           the row is hidden otherwise. JS keeps the
                           visibility in sync with the widthMode radio
                           after mount (see cb-section-settings-form). #}
                        <div data-cb-section-settings-form-target="maxWidthRow"
                             {% if form.widthMode.vars.value != 'centered' %}hidden{% endif %}>
                            {{ form_row(child) }}
                        </div>
                    {% else %}
                        {{ form_row(child) }}
                    {% endif %}
                {% endfor %}
            </div>
        </section>

        <section class="cb-sidebar__group">
            <h4 class="cb-sidebar__group-title">
                {{ 'cb.section.settings.tab.styling'|trans({}, 'content_blocks') }}
            </h4>
            <div class="cb-sidebar__group-body">
                {{ form_row(form.styling) }}
            </div>
        </section>

        {# Hidden submit trigger clicked by cb-autosave when an input event
           is debounced or a change/focusout fires. The submit is hijacked
           by cb-section-settings-form (fetch → cb:section:saved); the
           button is visually hidden because the user-facing Save header
           button is gone (autosave replaces it). #}
        <button type="submit"
                data-cb-sidebar-save
                class="cb-form-sr-only cb-sidebar__action-fallback">
            {{ 'cb.block.save'|trans({}, 'content_blocks') }}
        </button>
    {{ form_end(form) }}
</div>
