{# @var area \ContentBlocks\Entity\ContentArea #}
{# @var iframeUrl string #}
{# @var enableReplace bool #}
{# @var enableImportExport bool #}
<div class="cb-shell"
     data-controller="cb-builder"
     data-cb-builder-area-id-value="{{ area.id }}"
     data-cb-builder-iframe-url-value="{{ iframeUrl }}"
     data-cb-csrf-token="{{ csrf_token('content_blocks') }}">

    <div class="cb-shell__progress" data-cb-builder-target="progress" aria-hidden="true"></div>

    <header class="cb-shell__topbar">
        <div class="cb-shell__topbar-left">
            <button type="button"
                    class="cb-shell__close"
                    data-action="cb-builder#close"
                    aria-label="{{ 'cb.builder.close'|trans({}, 'content_blocks') }}">
                ×
            </button>
            {% if enableReplace|default(true) %}
                <button type="button"
                        class="cb-shell__replace"
                        data-action="cb-builder#openReplacePicker"
                        aria-haspopup="dialog"
                        aria-expanded="false"
                        title="{{ 'cb.builder.replace.open'|trans({}, 'content_blocks') }}"
                        aria-label="{{ 'cb.builder.replace.open'|trans({}, 'content_blocks') }}">
                    <span class="cb-shell__btn-icon" aria-hidden="true">⇆</span>
                    <span class="cb-shell__btn-label">{{ 'cb.builder.replace.open'|trans({}, 'content_blocks') }}</span>
                </button>
            {% endif %}
            {% if enableImportExport|default(true) %}
                <button type="button"
                        class="cb-shell__import-export"
                        data-action="cb-builder#openImportExport"
                        aria-haspopup="dialog"
                        aria-expanded="false"
                        title="{{ 'cb.builder.import_export.open'|trans({}, 'content_blocks') }}"
                        aria-label="{{ 'cb.builder.import_export.open'|trans({}, 'content_blocks') }}">
                    <span class="cb-shell__btn-icon" aria-hidden="true">⇅</span>
                    <span class="cb-shell__btn-label">{{ 'cb.builder.import_export.open'|trans({}, 'content_blocks') }}</span>
                </button>
            {% endif %}
        </div>

        <div class="cb-shell__topbar-center">
            <div class="cb-shell__viewport" role="group">
                <button type="button"
                        class="cb-shell__viewport-btn cb-shell__viewport-btn--active"
                        data-action="cb-builder#setViewport"
                        data-cb-builder-viewport-param="desktop"
                        title="Desktop">▭</button>
                <button type="button"
                        class="cb-shell__viewport-btn"
                        data-action="cb-builder#setViewport"
                        data-cb-builder-viewport-param="tablet"
                        title="Tablet">▢</button>
                <button type="button"
                        class="cb-shell__viewport-btn"
                        data-action="cb-builder#setViewport"
                        data-cb-builder-viewport-param="mobile"
                        title="Mobile">▯</button>
            </div>
        </div>

        <div class="cb-shell__topbar-right">
            <button type="button"
                    class="cb-shell__discard"
                    data-action="cb-builder#discard"
                    title="{{ 'cb.builder.discard'|trans({}, 'content_blocks') }}"
                    aria-label="{{ 'cb.builder.discard'|trans({}, 'content_blocks') }}"
                    {% if not area.hasUnpublishedChanges %}hidden{% endif %}>
                <span class="cb-shell__btn-icon" aria-hidden="true">↶</span>
                <span class="cb-shell__btn-label">{{ 'cb.builder.discard'|trans({}, 'content_blocks') }}</span>
            </button>
            <button type="button"
                    class="cb-shell__publish"
                    data-action="cb-builder#publish"
                    {% if not area.hasUnpublishedChanges %}disabled{% endif %}>
                {{ 'cb.builder.publish'|trans({}, 'content_blocks') }}
            </button>
        </div>
    </header>

    {# Replace-content picker (overlay panel rendered inside the shell). Stays
       hidden until the user clicks the Insert content button in the topbar.
       Skipped entirely when the feature is off (enable_replace form option),
       mirroring the Import/Export overlay below. #}
    {% if enableReplace|default(true) %}
    <div class="cb-replace-picker"
         data-cb-builder-target="replacePicker"
         role="dialog"
         aria-label="{{ 'cb.builder.replace.title'|trans({}, 'content_blocks') }}"
         data-i18n-cb-builder-replace-loading="{{ 'cb.builder.replace.loading'|trans({}, 'content_blocks') }}"
         data-i18n-cb-builder-replace-empty="{{ 'cb.builder.replace.empty'|trans({}, 'content_blocks') }}"
         data-i18n-cb-builder-replace-empty-filtered="{{ 'cb.builder.replace.empty_filtered'|trans({}, 'content_blocks') }}"
         data-i18n-cb-builder-replace-error="{{ 'cb.builder.replace.error'|trans({}, 'content_blocks') }}"
         data-i18n-cb-builder-replace-confirm="{{ 'cb.builder.replace.confirm'|trans({}, 'content_blocks') }}"
         hidden>
        <header class="cb-replace-picker__header">
            <h3 class="cb-replace-picker__title">{{ 'cb.builder.replace.title'|trans({}, 'content_blocks') }}</h3>
            <button type="button"
                    class="cb-replace-picker__close"
                    data-action="cb-builder#closeReplacePicker"
                    aria-label="{{ 'cb.builder.close'|trans({}, 'content_blocks') }}">×</button>
        </header>
        <div class="cb-replace-picker__body">
            <input type="search"
                   class="cb-replace-picker__search"
                   data-cb-builder-target="replacePickerSearch"
                   data-action="input->cb-builder#onReplacePickerSearch"
                   placeholder="{{ 'cb.builder.replace.search_placeholder'|trans({}, 'content_blocks') }}"
                   autocomplete="off">
            <ul class="cb-replace-picker__list"
                data-cb-builder-target="replacePickerList"
                role="listbox"></ul>
            <p class="cb-replace-picker__status"
               data-cb-builder-target="replacePickerStatus"
               role="status"
               aria-live="polite"></p>
        </div>
    </div>
    {% endif %}

    {# Import / Export overlay panel — anchored to the topbar Import/Export
       button. Identical positioning rules as the replace picker so both
       overlays read as siblings. Skipped entirely when the feature is off
       (enable_import_export form option). #}
    {% if enableImportExport|default(true) %}
    <div class="cb-import-export-picker"
         data-cb-builder-target="importExportPicker"
         role="dialog"
         aria-label="{{ 'cb.builder.import_export.title'|trans({}, 'content_blocks') }}"
         data-i18n-cb-builder-import-export-confirm="{{ 'cb.builder.import_export.confirm'|trans({}, 'content_blocks') }}"
         data-i18n-cb-builder-import-export-no-file="{{ 'cb.builder.import_export.no_file'|trans({}, 'content_blocks') }}"
         data-i18n-cb-builder-import-export-importing="{{ 'cb.builder.import_export.importing'|trans({}, 'content_blocks') }}"
         data-i18n-cb-builder-import-export-error="{{ 'cb.builder.import_export.error'|trans({}, 'content_blocks') }}"
         hidden>
        <header class="cb-import-export-picker__header">
            <h3 class="cb-import-export-picker__title">{{ 'cb.builder.import_export.title'|trans({}, 'content_blocks') }}</h3>
            <button type="button"
                    class="cb-import-export-picker__close"
                    data-action="cb-builder#closeImportExport"
                    aria-label="{{ 'cb.builder.close'|trans({}, 'content_blocks') }}">×</button>
        </header>
        <div class="cb-import-export-picker__body">
            <section class="cb-import-export-picker__section">
                <h4 class="cb-import-export-picker__heading">{{ 'cb.builder.import_export.export_heading'|trans({}, 'content_blocks') }}</h4>
                <p class="cb-import-export-picker__hint">{{ 'cb.builder.import_export.export_hint'|trans({}, 'content_blocks') }}</p>
                <button type="button"
                        class="cb-import-export-picker__btn cb-import-export-picker__btn--primary"
                        data-action="cb-builder#runExport">
                    {{ 'cb.builder.import_export.export_action'|trans({}, 'content_blocks') }}
                </button>
            </section>
            <div class="cb-import-export-picker__separator" aria-hidden="true"></div>
            <section class="cb-import-export-picker__section">
                <h4 class="cb-import-export-picker__heading">{{ 'cb.builder.import_export.import_heading'|trans({}, 'content_blocks') }}</h4>
                <p class="cb-import-export-picker__hint cb-import-export-picker__hint--warning">{{ 'cb.builder.import_export.import_hint'|trans({}, 'content_blocks') }}</p>
                <input type="file"
                       class="cb-import-export-picker__file"
                       data-cb-builder-target="importFile"
                       accept="application/json,.json">
                <button type="button"
                        class="cb-import-export-picker__btn cb-import-export-picker__btn--primary"
                        data-action="cb-builder#runImport">
                    {{ 'cb.builder.import_export.import_action'|trans({}, 'content_blocks') }}
                </button>
                <p class="cb-import-export-picker__status"
                   data-cb-builder-target="importExportStatus"
                   role="status"
                   aria-live="polite"></p>
            </section>
        </div>
    </div>
    {% endif %}

    {# Two-column main area: sidebar on the left, iframe on the right.
       The sidebar is permanent — it always occupies its own grid column
       and its content swaps based on the currently focused element
       (block / section / nothing). The collapsed state shrinks the
       column to a fly-out handle so the iframe can claim the full
       width when the user doesn't need the panel. #}
    <main class="cb-shell__main">
        <aside data-cb-builder-target="sidebar"
               class="cb-shell__sidebar"
               aria-label="{{ 'cb.block.edit'|trans({}, 'content_blocks') }}">
            <span class="cb-shell__sidebar-saved"
                  data-cb-builder-target="savedFlash"
                  role="status"
                  aria-live="polite"
                  hidden>✓ {{ 'cb.builder.saved'|trans({}, 'content_blocks') }}</span>
            <div class="cb-shell__sidebar-content" data-cb-builder-target="sidebarContent">
                {% include '@ContentBlocks/builder/sidebar_empty.html.twig' %}
            </div>
            {# Toggle: floating chip vertically centered on the sidebar's
               right edge, intentionally overhanging the iframe so it stays
               visible / clickable in both expanded and collapsed states. #}
            <button type="button"
                    class="cb-shell__sidebar-toggle"
                    data-cb-builder-target="sidebarToggle"
                    data-action="cb-builder#toggleSidebar"
                    aria-label="{{ 'cb.builder.toggle_sidebar'|trans({}, 'content_blocks') }}"
                    aria-expanded="true">
                <span class="cb-shell__sidebar-toggle-icon" aria-hidden="true">‹</span>
            </button>
            <div class="cb-shell__sidebar-resize"
                 data-cb-builder-target="sidebarResize"
                 data-action="mousedown->cb-builder#startSidebarResize touchstart->cb-builder#startSidebarResize"
                 aria-hidden="true"></div>
        </aside>
        <iframe data-cb-builder-target="iframe"
                class="cb-shell__iframe"
                title="{{ 'cb.builder.preview'|trans({}, 'content_blocks') }}"></iframe>
    </main>
</div>
