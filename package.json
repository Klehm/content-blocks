{
    "name": "@klehm/content-blocks",
    "description": "Page builder modulaire pour Symfony — Stimulus controllers & tests.",
    "license": "MIT",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "test": "npm run test:unit && npm run test:e2e",
        "test:unit": "vitest run",
        "test:unit:watch": "vitest",
        "pretest:e2e": "cd ../../apps/content-blocks-sandbox && rm -rf public/assets && php bin/console cache:clear -q && php bin/console asset-map:compile -q",
        "test:e2e": "npm run pretest:e2e && playwright test",
        "test:e2e:ui": "npm run pretest:e2e && playwright test --ui"
    },
    "symfony": {
        "controllers": {
            "cb-builder-launcher": {
                "main": "controllers/cb-builder-launcher_controller.js",
                "name": "cb-builder-launcher",
                "fetch": "eager",
                "enabled": true,
                "autoimport": {
                    "@klehm/content-blocks/styles/admin.css": true
                }
            },
            "cb-builder": {
                "main": "controllers/cb-builder_controller.js",
                "name": "cb-builder",
                "fetch": "eager",
                "enabled": true
            },
            "cb-autosave": {
                "main": "controllers/cb-autosave_controller.js",
                "name": "cb-autosave",
                "fetch": "eager",
                "enabled": true
            },
            "cb-section-settings-form": {
                "main": "controllers/cb-section-settings-form_controller.js",
                "name": "cb-section-settings-form",
                "fetch": "eager",
                "enabled": true
            },
            "cb-block-styling-form": {
                "main": "controllers/cb-block-styling-form_controller.js",
                "name": "cb-block-styling-form",
                "fetch": "eager",
                "enabled": true
            },
            "cb-spacing-link": {
                "main": "controllers/cb-spacing-link_controller.js",
                "name": "cb-spacing-link",
                "fetch": "eager",
                "enabled": true
            },
            "cb-viewport-tabs": {
                "main": "controllers/cb-viewport-tabs_controller.js",
                "name": "cb-viewport-tabs",
                "fetch": "eager",
                "enabled": true
            }
        }
    },
    "devDependencies": {
        "@hotwired/stimulus": "^3.2.0",
        "@playwright/test": "^1.52.0",
        "jsdom": "^26.1.0",
        "vitest": "^3.2.1"
    }
}
